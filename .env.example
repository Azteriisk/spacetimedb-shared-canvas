# SpacetimeDB Configuration
# The name of your database as published with `spacetime publish <name>`
VITE_SPACETIMEDB_DB_NAME=REPLACE_WITH_YOUR_DB_NAME
VITE_SPACETIMEDB_HOST=wss://maincloud.spacetimedb.com

# Clerk Authentication
# Get these from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Admin Configuration
# Your Clerk User ID (used to identify you as the admin in the Admin panel)
VITE_ADMIN_CLERK_ID=user_...
